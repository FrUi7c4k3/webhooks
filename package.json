{
  "name": "webhook-receiver",
  "version": "1.0.0",
  "description": "A simple webhook receiver in TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev:receiver": "ts-node src/receiver/server.ts",
    "dev:sender": "ts-node src/sender/server.ts",
    "start:receiver": "node dist/receiver/server.js",
    "start:sender": "node dist/sender/server.js",
    "test": "jest"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
